---
import BlogLayout from "../../layouts/BlogLayout.astro";
import TableOfContents from "../../components/blog/TableOfContents.astro";
import SocialShare from "../../components/blog/SocialShare.astro";
import AuthorBio from "../../components/blog/AuthorBio.astro";
import RelatedPosts from "../../components/blog/RelatedPosts.astro";
import JsonLd from "../../components/common/JsonLd.astro";
import { loadAllPosts, loadAllAuthors, extractHeadings, injectHeadingIds } from "../../lib/markdown.js";
import { formatDate, readingTime, postHref } from "../../lib/utils.js";
import { SITE_URL } from "../../lib/constants.js";

export async function getStaticPaths() {
  const posts = loadAllPosts();
  const authors = loadAllAuthors();

  return posts.map((post, i) => {
    const authorSlug = Array.isArray(post.author) ? post.author[0] : post.author;
    const authorData = authors.find((a) => a.slug === authorSlug) || null;

    const relatedPosts = posts
      .filter((p) => p.slug !== post.slug)
      .filter((p) => {
        const pTags = Array.isArray(p.tags) ? p.tags : [];
        const postTags = Array.isArray(post.tags) ? post.tags : [];
        return pTags.some((t) => postTags.includes(t));
      })
      .slice(0, 3);

    return {
      params: { slug: post.slug },
      props: { post, relatedPosts, authorData },
    };
  });
}

const { post, relatedPosts, authorData } = Astro.props;
const bodyWithIds = injectHeadingIds(post.body || "");
const headings = extractHeadings(bodyWithIds);
const mins = readingTime(post.body || "");
const postUrl = `${SITE_URL}/blog/${post.slug}/`;
const authorName = authorData?.name || "Susmita Sarma";

const firstTag = Array.isArray(post.tags) ? post.tags[0] : post.tags;
---

<BlogLayout
  title={post.meta_title || post.title}
  description={post.meta_description || post.excerpt || ""}
  canonicalUrl={postUrl}
  ogImage={post.featured_image}
  ogType="article"
>
  <JsonLd slot="head" post={post} authorName={authorName} />

  <article class="max-w-5xl mx-auto px-4 sm:px-6 py-10">
    <!-- Post header -->
    <header class="mb-8">
      {firstTag && (
        <a
          href={`/blog/tag/${firstTag.toLowerCase().replace(/\s+/g, "-")}/`}
          class="inline-block text-xs font-semibold uppercase tracking-wider text-accent mb-3 hover:underline"
        >
          {firstTag}
        </a>
      )}
      <h1 class="text-3xl sm:text-4xl font-bold text-primary leading-tight mb-4">
        {post.title}
      </h1>

      <!-- Author row -->
      <div class="flex items-center gap-3 mb-4">
        {authorData?.avatar && (
          <img
            src={authorData.avatar}
            alt={authorData.name}
            class="w-9 h-9 rounded-full object-cover"
            loading="eager"
            decoding="async"
          />
        )}
        <div class="text-sm text-gray-600">
          {authorData && (
            <a href={`/blog/author/${authorData.slug}/`} class="font-medium text-primary hover:text-accent transition-colors">
              {authorData.name}
            </a>
          )}
          <div class="flex items-center gap-2 text-gray-400 text-xs mt-0.5">
            <time datetime={post.date}>{formatDate(post.date)}</time>
            <span aria-hidden="true">&middot;</span>
            <span>{mins} min read</span>
          </div>
        </div>
      </div>
    </header>

    <!-- Featured image -->
    {post.featured_image && (
      <div class="mb-8 rounded-2xl overflow-hidden aspect-[16/9] bg-gray-100">
        <img
          src={post.featured_image}
          alt={post.title}
          class="w-full h-full object-cover"
          loading="eager"
          decoding="async"
        />
      </div>
    )}

    <!-- Body: TOC sidebar + article -->
    <div class="post-body-wrap">
      <TableOfContents headings={headings} />
      <div class="editor-content">
        <Fragment set:html={bodyWithIds} />
        <SocialShare url={postUrl} title={post.title} />
      </div>
    </div>

    <!-- Author bio -->
    <AuthorBio author={authorData} />
  </article>

  <!-- Related posts -->
  {relatedPosts.length > 0 && (
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <RelatedPosts posts={relatedPosts} />
    </div>
  )}
</BlogLayout>
