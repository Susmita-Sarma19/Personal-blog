---
import BlogLayout from "../../layouts/BlogLayout.astro";
---

<BlogLayout
  title="About | Half Baked"
  description="A little about Susmita Sarma — writer, builder, thinker."
  canonicalUrl="https://half-baked-blog.netlify.app/about/"
>
  <div class="max-w-2xl mx-auto px-4 sm:px-6 py-16">
    <h1 class="text-3xl sm:text-4xl font-bold text-primary mb-6">About</h1>
    <div class="prose prose-lg text-gray-700">
      <p>
        Hi, I'm Susmita. I work at the intersection of content and technology,
        and this blog is where I think out loud.
      </p>
      <p>
        I write about work and craft, books worth reading, and ideas that
        deserve more than a fleeting thought.
      </p>
      <p>
        Find me on
        <a href="https://linkedin.com/in/susmitasarma" target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">LinkedIn</a>
        or
        <a href="https://x.com/susmitasarma" target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">X</a>.
      </p>
    </div>
  </div>
</BlogLayout>
