---
const { post, authorName } = Astro.props;

const siteUrl = "https://susmita.blog";
const postUrl = `${siteUrl}/blog/${post.slug}/`;

const schema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.meta_title || post.title,
  description: post.meta_description || post.excerpt || "",
  url: postUrl,
  datePublished: post.date,
  dateModified: post.updated || post.date,
  image: post.featured_image || "",
  author: {
    "@type": "Person",
    name: authorName || "Susmita Sarma",

    url: `${siteUrl}/blog/author/${post.author || "susmita-sarma"}/`,
  },
  publisher: {
    "@type": "Organization",
    name: "Half Baked",
    url: siteUrl,
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": postUrl,
  },
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} is:inline />
