---
import { formatDate, readingTime, postHref } from "../../lib/utils.js";

const { post } = Astro.props;
const href = postHref(post);
const mins = readingTime(post.body || "");
const firstTag = Array.isArray(post.tags) ? post.tags[0] : null;
---

<article class="bg-white rounded-2xl overflow-hidden border border-gray-100 shadow-sm mb-12">
  <div class="flex flex-col lg:flex-row">
    <!-- Text side -->
    <div class="flex flex-col justify-center p-8 lg:p-10 lg:w-1/2">
      {firstTag && (
        <a
          href={`/blog/tag/${firstTag.toLowerCase().replace(/\s+/g, "-")}/`}
          class="inline-block text-xs font-semibold uppercase tracking-wider text-accent mb-4 hover:underline"
        >
          {firstTag}
        </a>
      )}
      <h2 class="text-2xl sm:text-3xl font-bold text-primary leading-tight mb-4">
        <a href={href} class="hover:text-accent transition-colors">
          {post.title}
        </a>
      </h2>
      {post.excerpt && (
        <p class="text-gray-600 text-base leading-relaxed mb-6 line-clamp-3">
          {post.excerpt}
        </p>
      )}
      <div class="flex items-center gap-3 text-sm text-gray-500 mb-6">
        <time datetime={post.date}>{formatDate(post.date)}</time>
        <span aria-hidden="true">&middot;</span>
        <span>{mins} min read</span>
      </div>
      <a
        href={href}
        class="self-start inline-flex items-center gap-2 bg-primary text-white text-sm font-semibold px-6 py-3 rounded-full hover:bg-accent transition-colors"
      >
        Read more
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>

    <!-- Image side -->
    {post.featured_image && (
      <a href={href} class="block lg:w-1/2 min-h-[240px] lg:min-h-0 overflow-hidden bg-gray-100">
        <img
          src={post.featured_image}
          alt={post.title}
          class="w-full h-full object-cover"
          loading="eager"
          decoding="async"
        />
      </a>
    )}
  </div>
</article>
