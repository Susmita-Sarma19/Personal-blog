---
const year = new Date().getFullYear();
---

<footer class="bg-primary text-white mt-16">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
      <!-- Brand -->
      <div>
        <a href="/blog/" class="text-xl font-bold hover:text-accent transition-colors">
          Half Baked
        </a>
        <p class="text-sm text-white/60 mt-1">Thinking out loud, one post at a time.</p>
      </div>

      <!-- Social links -->
      <div class="flex items-center gap-4">
        <a
          href="https://linkedin.com/in/susmitasarma"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="text-white/70 hover:text-accent transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
          </svg>
        </a>
        <a
          href="https://x.com/susmitasarma"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="X (Twitter)"
          class="text-white/70 hover:text-accent transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.748l7.73-8.835L1.254 2.25H8.08l4.259 5.631zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
        <a
          href="/rss.xml"
          aria-label="RSS Feed"
          class="text-white/70 hover:text-accent transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/>
          </svg>
        </a>
      </div>
    </div>

    <div class="mt-8 pt-6 border-t border-white/10 text-center text-xs text-white/40">
      &copy; {year} Half Baked. All rights reserved.
    </div>
  </div>
</footer>
